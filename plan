<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>KLOVER · Programa de Transformación Comercial</title>
<link rel="preconnect" href="https://fonts.googleapis.com"><link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Heebo:wght@400;500;600;700;800&family=Quicksand:wght@400;500;600;700&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet">
<style>
:root{--ink:#14161c;--ink2:#4b5160;--ink3:#878d9c;--bg:#fff;--bg2:#f6f7f9;--line:#e9ebf1;--line2:#dde0e8;
--dark:#0e1d14;--indigo:#4848de;--green:#2f7d44;--amber:#9a6b08;--cyan:#0e7f97;--red:#c0392b;--mint:#9fe1cb;
--grad:linear-gradient(115deg,#5b9655,#4848de);--graddark:linear-gradient(115deg,#8fe49a,#9b97ff);
--head:'Heebo',sans-serif;--body:'Quicksand',sans-serif;--mono:'JetBrains Mono',monospace;}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth;scroll-padding-top:74px}
body{background:var(--bg);color:var(--ink);font-family:var(--body);font-size:15.5px;line-height:1.62;-webkit-font-smoothing:antialiased}
h1,h2,h3,h4{font-family:var(--head);letter-spacing:-.02em;line-height:1.12;color:var(--ink)}
a{color:inherit;text-decoration:none}strong,b{color:var(--ink)}
.grad{background:var(--grad);-webkit-background-clip:text;background-clip:text;color:transparent}
nav{position:sticky;top:0;z-index:70;background:rgba(255,255,255,.92);backdrop-filter:blur(12px);border-bottom:1px solid var(--line)}
nav .in{max-width:1240px;margin:0 auto;display:flex;align-items:center;gap:14px;height:58px;padding:0 22px}
.logo{display:flex;align-items:center;gap:9px;font-family:var(--head);font-weight:800;font-size:17px}.logo svg{width:25px;height:25px}
.klogo{width:26px;height:26px;flex:none;border-radius:50%;display:inline-block;background:url(data:image/png;base64,) center/contain no-repeat}
.logo small{font-family:var(--body);font-weight:600;font-size:11px;letter-spacing:.1em;color:var(--ink3);text-transform:uppercase;border-left:1px solid var(--line2);padding-left:9px}
.ncta{margin-left:auto;display:flex;gap:8px}
.btn{font-family:var(--head);font-weight:700;font-size:12.5px;padding:9px 16px;border-radius:9px;border:1px solid var(--line2);background:#fff;color:var(--ink2);cursor:pointer;display:inline-flex;align-items:center;gap:6px}
.btn.pri{color:#fff;background:var(--grad);border:none}
@media(max-width:620px){.logo small{display:none}.btn{padding:8px 12px}}
.shell{max-width:1240px;margin:0 auto;display:grid;grid-template-columns:262px 1fr;gap:34px;padding:0 22px}
aside{position:sticky;top:58px;height:calc(100vh - 58px);overflow-y:auto;padding:22px 6px 40px 0;border-right:1px solid var(--line)}
aside .grp{font-family:var(--mono);font-size:10px;font-weight:600;letter-spacing:.1em;text-transform:uppercase;color:var(--ink3);margin:16px 0 6px}
aside a{display:block;font-size:12.7px;font-weight:600;color:var(--ink2);padding:5px 10px;border-radius:7px;border-left:2px solid transparent}
aside a:hover{background:var(--bg2);color:var(--ink)}
aside a.on{color:var(--indigo);border-left-color:var(--indigo);background:#f3f3fe}
main{min-width:0;padding:16px 0 70px}
@media(max-width:920px){.shell{grid-template-columns:1fr}aside{display:none}}
.hero{background:var(--dark);color:#fff;border-radius:0 0 22px 22px;overflow:hidden;position:relative;margin-bottom:14px}
.hero .pad{padding:46px 40px 42px;position:relative;z-index:2;max-width:780px}
.hero .cl{position:absolute;right:-50px;top:50%;transform:translateY(-50%);width:330px;height:330px;opacity:.85}
.hero .kick{font-family:var(--head);font-weight:700;font-size:12px;letter-spacing:.16em;text-transform:uppercase;color:var(--mint)}
.hero h1{font-size:40px;font-weight:800;letter-spacing:-.03em;margin-top:12px;color:#fff;line-height:1.08}
.hero h1 .g{background:var(--graddark);-webkit-background-clip:text;background-clip:text;color:transparent}
.hero p{color:#c4d2c8;font-size:16.5px;margin-top:14px;max-width:62ch}
.hero .meta{margin-top:20px;display:flex;flex-wrap:wrap;gap:9px 24px;font-size:12.5px;color:#8fae9a}.hero .meta b{color:#dfeee6}
.hero .pbtn{margin-top:22px;display:inline-flex;align-items:center;gap:8px;background:#fff;color:var(--dark);font-family:var(--head);font-weight:800;font-size:14px;padding:11px 20px;border-radius:10px;border:none;cursor:pointer}
@media(max-width:700px){.hero .pad{padding:34px 24px}.hero h1{font-size:28px}.hero .cl{display:none}}
.sec{padding:34px 0;border-bottom:1px solid var(--line)}.sec:last-child{border:none}
.kicker{font-family:var(--mono);font-size:12px;font-weight:600;color:var(--indigo)}
.sec h2{font-size:26px;font-weight:800;letter-spacing:-.025em;margin:5px 0 4px}
.sec>.lead{color:var(--ink2);font-size:16px;margin-bottom:14px;max-width:80ch}
.sec h3{font-size:18px;font-weight:800;margin:24px 0 8px}
.sec h4{font-size:14.5px;font-weight:800;margin:16px 0 6px}
.sec p{margin-bottom:10px;max-width:84ch}
.sec ul{list-style:none;margin:6px 0 12px}.sec ul li{position:relative;padding-left:20px;margin-bottom:7px;max-width:84ch}
.sec ul li::before{content:"";position:absolute;left:0;top:9px;width:7px;height:7px;border-radius:50%;background:var(--grad)}
.sec ol{margin:6px 0 12px 20px}.sec ol li{margin-bottom:7px;max-width:84ch}
.guide{background:#f3f3fe;border:1px solid #dcdcfb;border-left:4px solid var(--indigo);border-radius:12px;padding:16px 20px;margin:14px 0}
.guide .gh{font-family:var(--head);font-weight:800;font-size:13px;letter-spacing:.03em;text-transform:uppercase;color:var(--indigo);margin-bottom:8px}
.guide ol{margin:4px 0 0 18px}.guide ul{margin:4px 0 0}.guide li{margin-bottom:6px;font-size:14.5px}.guide p{font-size:14.5px;margin:0 0 6px;max-width:none}.guide p:last-child{margin-bottom:0}
.guide.green{background:#eef7f0;border-color:#cce6d3;border-left-color:var(--green)}.guide.green .gh{color:var(--green)}
.guide.amber{background:#fbf4e6;border-color:#ecdcb6;border-left-color:var(--amber)}.guide.amber .gh{color:var(--amber)}
.note{background:var(--bg2);border:1px solid var(--line);border-radius:10px;padding:12px 16px;font-size:14px;color:var(--ink2);margin:10px 0}.note b{color:var(--ink)}
.note.warn{background:#fdeef0;border-color:#f3d4da}
.term{border-bottom:2px dotted var(--indigo);cursor:help;font-weight:600;color:var(--ink)}
.grid{display:grid;gap:14px}.g2{grid-template-columns:1fr 1fr}.g3{grid-template-columns:repeat(3,1fr)}.g4{grid-template-columns:repeat(4,1fr)}
@media(max-width:760px){.g2,.g3,.g4{grid-template-columns:1fr}}
.card{background:#fff;border:1px solid var(--line);border-radius:13px;padding:18px}.card h4{margin:0 0 6px;font-size:15px}
.card p,.card li{font-size:13.5px;color:var(--ink2)}.card .tag{font-family:var(--mono);font-size:11px;font-weight:600;letter-spacing:.05em;text-transform:uppercase}
.card ul{margin:6px 0 0}.card ul li{padding-left:16px;margin-bottom:5px}.card ul li::before{top:8px;width:5px;height:5px}
.dotP{color:var(--indigo)}.dotS{color:var(--green)}.dotR{color:var(--amber)}.dotC{color:var(--cyan)}
.tbl{width:100%;border-collapse:collapse;font-size:13.5px;margin:8px 0 14px;border:1px solid var(--line);border-radius:12px;overflow:hidden}
.tbl th{background:var(--dark);color:#fff;font-family:var(--head);font-weight:700;font-size:12px;text-align:left;padding:10px 12px}
.tbl td{padding:10px 12px;border-top:1px solid var(--line);vertical-align:top;color:var(--ink2)}.tbl td b,.tbl td strong{color:var(--ink)}
.tbl tr:nth-child(even) td{background:#fbfbfd}.tbl.mono td:first-child{font-family:var(--head);font-weight:700;color:var(--ink)}
.tbl.center td,.tbl.center th{text-align:center}.tbl.center td:first-child{text-align:left}
.scrollx{overflow-x:auto}
.badge{font-family:var(--mono);font-size:11px;font-weight:600;padding:2px 8px;border-radius:6px;color:#fff;display:inline-block}
.pill{font-family:var(--head);font-size:11px;font-weight:700;padding:2px 9px;border-radius:999px;display:inline-block}
.pill.act{background:#f3f3fe;color:var(--indigo)}.pill.adv{background:#eef7f0;color:var(--green)}.pill.res{background:#fbf4e6;color:var(--amber)}
/* STAT BIG */
.stats{display:grid;grid-template-columns:repeat(4,1fr);gap:14px;margin:14px 0}@media(max-width:760px){.stats{grid-template-columns:1fr 1fr}}
.stat{background:var(--dark);color:#fff;border-radius:13px;padding:18px}.stat .n{font-family:var(--head);font-weight:800;font-size:30px;color:var(--mint);line-height:1}.stat .l{font-size:12.5px;color:#c4d2c8;margin-top:6px}
/* ROUTINE */
.routine{display:grid;grid-template-columns:repeat(3,1fr);gap:12px;margin:12px 0}@media(max-width:760px){.routine{grid-template-columns:1fr}}
.rcard{border:1px solid var(--line);border-radius:13px;overflow:hidden}
.rcard .rh{padding:12px 16px;color:#fff;font-family:var(--head);font-weight:800;font-size:14px}
.rcard.r1 .rh{background:var(--indigo)}.rcard.r2 .rh{background:var(--green)}.rcard.r3 .rh{background:var(--amber)}
.rcard .rb{padding:14px 16px}.rcard .rb .m{display:flex;justify-content:space-between;align-items:baseline;border-bottom:1px dashed var(--line);padding:7px 0;font-size:13.5px}
.rcard .rb .m:last-child{border:none}.rcard .rb .m b{font-family:var(--head);font-size:18px;color:var(--ink)}
/* TIMELINE / ROADMAP */
.tl{position:relative;margin:16px 0 6px;padding-left:8px}
.tlitem{position:relative;padding:0 0 8px 30px;border-left:2px solid var(--line2);margin-left:8px}
.tlitem:last-child{border-left-color:transparent}
.tlitem .dot{position:absolute;left:-9px;top:2px;width:16px;height:16px;border-radius:50%;background:var(--grad);border:3px solid #fff;box-shadow:0 0 0 1px var(--line2)}
.tlitem .ph{font-family:var(--head);font-weight:800;font-size:15.5px;margin-bottom:2px}
.tlitem .pr{font-family:var(--mono);font-size:11px;font-weight:600;color:var(--indigo);text-transform:uppercase;letter-spacing:.04em}
.tlbox{background:#fff;border:1px solid var(--line);border-radius:12px;padding:14px 16px;margin-top:8px}
.tlbox .row{display:grid;grid-template-columns:120px 1fr;gap:8px;font-size:13.5px;padding:5px 0;border-top:1px solid var(--line)}
.tlbox .row:first-child{border-top:none}.tlbox .row .k{font-family:var(--head);font-weight:700;color:var(--ink);font-size:12.5px}
@media(max-width:600px){.tlbox .row{grid-template-columns:1fr;gap:2px}}
/* TRAINING MONTHS */
.month{border:1px solid var(--line);border-radius:13px;overflow:hidden;margin-bottom:12px}
.month .mh{display:flex;align-items:center;gap:12px;padding:13px 18px;background:var(--bg2);border-bottom:1px solid var(--line)}
.month .mn{width:34px;height:34px;border-radius:9px;background:var(--grad);color:#fff;display:grid;place-items:center;font-family:var(--head);font-weight:800;font-size:15px;flex:none}
.month .mt{font-family:var(--head);font-weight:800;font-size:15.5px}.month .mt small{display:block;font-family:var(--body);font-weight:600;font-size:12px;color:var(--ink3)}
.month .mb{padding:14px 18px;display:grid;grid-template-columns:1fr 1fr;gap:8px 26px}@media(max-width:700px){.month .mb{grid-template-columns:1fr}}
.month .mb .blk h5{font-family:var(--head);font-weight:800;font-size:12px;text-transform:uppercase;letter-spacing:.04em;color:var(--indigo);margin:4px 0 4px}
.month .mb .blk p,.month .mb .blk li{font-size:13.5px;color:var(--ink2)}.month .mb .blk ul{margin:0}.month .mb .blk ul li{padding-left:15px;margin-bottom:4px}.month .mb .blk ul li::before{top:8px;width:5px;height:5px}
/* SCRIPTS */
.script{background:#fff;border:1px solid var(--line);border-left:4px solid var(--indigo);border-radius:12px;padding:16px;position:relative;margin-bottom:14px}
.script .sh{font-family:var(--head);font-weight:800;font-size:14.5px;margin-bottom:3px;padding-right:70px}
.script .sm{font-family:var(--mono);font-size:10.5px;color:var(--ink3);text-transform:uppercase;font-weight:600;margin-bottom:9px}
.script .sb{font-size:13.5px;color:var(--ink2)}.script .sb p{margin-bottom:7px;max-width:none}.script .sb em{color:var(--ink3);font-style:normal;font-size:12.5px}
.copy{position:absolute;top:13px;right:13px;font-family:var(--head);font-weight:700;font-size:11px;color:var(--ink2);background:var(--bg2);border:1px solid var(--line2);border-radius:7px;padding:5px 9px;cursor:pointer}
.copy.done{background:#eef7f0;border-color:#cce6d3;color:var(--green)}
.script.s-li{border-left-color:var(--cyan)}.script.s-mail{border-left-color:var(--indigo)}.script.s-call{border-left-color:var(--green)}.script.s-follow{border-left-color:var(--amber)}.script.s-ref{border-left-color:var(--dark)}
/* AGENDA */
.agenda{border:1px solid var(--line);border-radius:12px;overflow:hidden;margin:10px 0}
.agenda .arow{display:grid;grid-template-columns:64px 1fr;gap:0;border-top:1px solid var(--line)}.agenda .arow:first-child{border-top:none}
.agenda .at{background:var(--bg2);font-family:var(--mono);font-weight:600;font-size:12px;color:var(--indigo);padding:11px 12px;display:flex;align-items:center}
.agenda .ad{padding:11px 14px;font-size:13.5px}.agenda .ad b{color:var(--ink)}
/* TABS */
.tabs{display:flex;gap:7px;flex-wrap:wrap;margin:12px 0 16px}
.tab{font-family:var(--head);font-weight:700;font-size:12.5px;padding:7px 14px;border-radius:999px;border:1px solid var(--line2);background:#fff;color:var(--ink2);cursor:pointer}
.tab.on{color:#fff;border-color:transparent;background:var(--indigo)}
.panel{display:none}.panel.on{display:block}
.kanban{display:grid;grid-template-columns:repeat(7,1fr);gap:8px;margin:12px 0;overflow-x:auto}
.kcol{min-width:120px;border:1px solid var(--line);border-radius:10px;overflow:hidden}
.kcol .kh{padding:8px 10px;font-family:var(--head);font-weight:800;font-size:11.5px;color:#fff;background:var(--dark);text-align:center}
.kcol .kb{padding:9px 10px;font-size:11.5px;color:var(--ink2);min-height:60px}
footer{background:var(--dark);color:#9fb3a6;padding:30px 22px;text-align:center;font-size:13px;border-radius:22px 22px 0 0;margin-top:10px}footer b{color:#fff}
.reveal{opacity:0;transform:translateY(16px);transition:.5s}.reveal.in{opacity:1;transform:none}
/* PRESENTATION */
#present{position:fixed;inset:0;z-index:200;background:var(--dark);color:#fff;display:none}
#present.open{display:block}
.pbar{position:absolute;top:0;left:0;height:4px;background:var(--graddark);width:0;transition:width .3s;z-index:5}
.pslide{position:absolute;inset:0;padding:8vh 9vw;flex-direction:column;justify-content:center;display:none}
.pslide.on{display:flex;animation:pin .45s ease}
@keyframes pin{from{opacity:0;transform:translateY(22px)}to{opacity:1;transform:none}}
.pslide .pk{font-family:var(--head);font-weight:700;font-size:15px;letter-spacing:.14em;text-transform:uppercase;color:var(--mint)}
.pslide h2{font-size:clamp(28px,5vw,54px);font-weight:800;letter-spacing:-.03em;margin:14px 0 6px;color:#fff;line-height:1.05}
.pslide h2 .g{background:var(--graddark);-webkit-background-clip:text;background-clip:text;color:transparent}
.pslide .psub{font-size:clamp(15px,2vw,21px);color:#c4d2c8;max-width:66ch;margin-bottom:18px}
.pslide ul{list-style:none;display:flex;flex-direction:column;gap:13px;margin-top:8px}
.pslide ul li{position:relative;padding-left:34px;font-size:clamp(15px,2vw,22px);color:#e6efe9;max-width:64ch}
.pslide ul li::before{content:"";position:absolute;left:0;top:.5em;width:14px;height:14px;border-radius:4px;background:var(--graddark)}
.pslide ul li b{color:#fff}
.pcards{display:grid;grid-template-columns:repeat(3,1fr);gap:16px;margin-top:14px}
@media(max-width:760px){.pcards{grid-template-columns:1fr}}
.pcard{background:rgba(255,255,255,.05);border:1px solid rgba(159,225,203,.2);border-radius:16px;padding:22px}
.pcard .n{font-family:var(--head);font-weight:800;font-size:30px;color:var(--mint)}
.pcard h3{color:#fff;font-size:19px;margin:6px 0 6px}.pcard p{color:#c4d2c8;font-size:14.5px}
.pcl{position:absolute;right:5vw;bottom:6vh;width:240px;height:240px;opacity:.5}
.pctrl{position:absolute;bottom:0;left:0;right:0;display:flex;align-items:center;gap:14px;padding:18px 5vw;z-index:6}
.pbtn2{width:46px;height:46px;border-radius:50%;border:1px solid rgba(255,255,255,.2);background:rgba(255,255,255,.07);color:#fff;font-size:20px;cursor:pointer;display:grid;place-items:center}
.pbtn2:hover{background:rgba(255,255,255,.15)}
.pdots{display:flex;gap:7px;margin:0 auto;flex-wrap:wrap;justify-content:center}
.pdot{width:8px;height:8px;border-radius:50%;background:rgba(255,255,255,.25);cursor:pointer}.pdot.on{background:var(--mint);width:22px;border-radius:5px}
.pcount{font-family:var(--mono);font-size:13px;color:#8fae9a}
.pexit{position:absolute;top:18px;right:24px;background:rgba(255,255,255,.08);border:1px solid rgba(255,255,255,.18);color:#fff;font-family:var(--head);font-weight:700;font-size:13px;padding:8px 14px;border-radius:9px;cursor:pointer;z-index:6}
.plogo{position:absolute;top:18px;left:5vw;display:flex;align-items:center;gap:8px;font-family:var(--head);font-weight:800;color:#fff;z-index:6}
@media print{nav,aside,#present{display:none!important}.shell{grid-template-columns:1fr}main{padding:0}.sec{break-inside:avoid;padding:18px 0}.reveal{opacity:1!important;transform:none!important}.panel{display:block!important}.hero{border-radius:0}.month,.script,.card,.tlbox{break-inside:avoid}}
</style>
</head>
